{
  "installCommand": "npm install",
  "functions": {
    "api/[[...path]].js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/[[...path]]",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    }
  ]
}