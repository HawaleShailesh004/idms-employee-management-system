{
  "installCommand": "npm install && npm install --prefix ../client",
  "buildCommand": "npm run build --prefix ../client && rm -rf public && cp -r ../client/dist public",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/src/index.js" },
    { "source": "/uploads/(.*)", "destination": "/src/index.js" },
    { "source": "/((?!api/|uploads/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "src/index.js": {
      "maxDuration": 30
    }
  }
}
