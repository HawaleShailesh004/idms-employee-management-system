{
  "installCommand": "npm install --prefix server && npm install --prefix client",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/src/index.js" },
    { "source": "/uploads/(.*)", "destination": "/server/src/index.js" },
    { "source": "/((?!api/|uploads/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "server/src/index.js": {
      "maxDuration": 30
    }
  }
}
